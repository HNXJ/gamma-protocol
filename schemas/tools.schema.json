{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GAMMA Tools Schema",
  "description": "JSON schema for tool definitions in the GAMMA ecosystem. Tools are executable components that perform specific computational or operational tasks.",
  "type": "object",
  "required": ["tool_id", "name", "description", "type", "input_contract"],
  "properties": {
    "tool_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Unique identifier for the tool (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the tool"
    },
    "description": {
      "type": "string",
      "description": "Purpose and capabilities of the tool"
    },
    "type": {
      "type": "string",
      "enum": ["computational", "validation", "transformation", "analysis", "adapter", "utility"],
      "description": "Category of tool"
    },
    "plane": {
      "type": "string",
      "enum": ["Control", "Execution", "Truth", "Observation"],
      "description": "Primary GAMMA plane association"
    },
    "version": {
      "type": "string",
      "description": "Semantic versioning (MAJOR.MINOR.PATCH)"
    },
    "author": {
      "type": "string",
      "description": "Creator/maintainer of the tool"
    },
    "input_contract": {
      "type": "object",
      "required": ["parameters"],
      "properties": {
        "parameters": {
          "type": "object",
          "description": "Mapping of parameter names to their specifications",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["string", "number", "integer", "boolean", "array", "object"],
                "description": "Parameter data type"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this parameter is required"
              },
              "description": {
                "type": "string",
                "description": "Parameter description and usage"
              },
              "default": {
                "description": "Default value if not provided"
              }
            }
          }
        }
      }
    },
    "output_contract": {
      "type": "object",
      "required": ["return_type"],
      "properties": {
        "return_type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "array", "object", "null"],
          "description": "Type of return value"
        },
        "description": {
          "type": "string",
          "description": "Description of output format and semantics"
        },
        "schema": {
          "type": "object",
          "description": "JSON schema for output validation (if return_type is object or array)"
        }
      }
    },
    "implementation": {
      "type": "object",
      "required": ["language", "location"],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python", "javascript", "typescript", "bash", "go", "rust"],
          "description": "Implementation language"
        },
        "location": {
          "type": "string",
          "description": "File path to implementation"
        },
        "entry_point": {
          "type": "string",
          "description": "Function or method name for entry point"
        },
        "dependencies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Required packages or modules"
        }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "time_complexity": {
          "type": "string",
          "description": "Algorithmic time complexity (e.g., O(n), O(log n))"
        },
        "space_complexity": {
          "type": "string",
          "description": "Algorithmic space complexity (e.g., O(n), O(1))"
        },
        "typical_duration_ms": {
          "type": "number",
          "description": "Typical execution duration in milliseconds"
        },
        "max_duration_ms": {
          "type": "number",
          "description": "Maximum acceptable execution duration"
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "pre_conditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Conditions that must be true before execution"
        },
        "post_conditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Guarantees about output if execution succeeds"
        },
        "invariants": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Properties that remain true throughout execution"
        },
        "error_handling": {
          "type": "string",
          "enum": ["throws", "returns_error", "returns_null", "silent_fail"],
          "description": "How errors are communicated"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Categorization tags for discoverability"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "experimental", "archived"],
      "description": "Current status of the tool"
    },
    "testing": {
      "type": "object",
      "properties": {
        "unit_tests": {
          "type": "string",
          "description": "Path to unit tests"
        },
        "integration_tests": {
          "type": "string",
          "description": "Path to integration tests"
        },
        "test_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Code coverage percentage"
        }
      }
    }
  },
  "additionalProperties": false
}

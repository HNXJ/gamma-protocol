{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GAMMA Registry Schema",
  "description": "JSON schema for the central GAMMA harness and tool registry. The registry is the authoritative ledger of all registered harnesses, skills, and executable tools in the GAMMA ecosystem.",
  "type": "object",
  "required": ["registry_id", "version", "timestamp", "entries"],
  "properties": {
    "registry_id": {
      "type": "string",
      "const": "gamma-central-registry",
      "description": "Unique identifier for the central registry"
    },
    "version": {
      "type": "string",
      "description": "Registry schema version (MAJOR.MINOR.PATCH)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last registry update"
    },
    "maintainer": {
      "type": "string",
      "description": "Owner/maintainer of the registry"
    },
    "entries": {
      "type": "array",
      "description": "List of registered harnesses and tools",
      "items": {
        "type": "object",
        "required": ["entry_id", "type", "harness_id", "registration_date"],
        "properties": {
          "entry_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$",
            "description": "Unique entry identifier"
          },
          "type": {
            "type": "string",
            "enum": ["harness", "skill", "tool", "adapter"],
            "description": "Type of registered entity"
          },
          "harness_id": {
            "type": "string",
            "description": "Reference to the harness or tool ID"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          },
          "description": {
            "type": "string",
            "description": "Purpose and capabilities"
          },
          "registration_date": {
            "type": "string",
            "format": "date-time",
            "description": "When this entry was registered"
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "experimental", "archived"],
            "description": "Current status of the entry"
          },
          "plane": {
            "type": "string",
            "enum": ["Control", "Execution", "Truth", "Observation"],
            "description": "GAMMA plane association"
          },
          "protocol": {
            "type": "string",
            "enum": ["BETA", "ALPHA", "GAMMA", "DELTA", "THETA", "GAMMA-BURST"],
            "description": "Primary protocol governing this entry"
          },
          "location": {
            "type": "string",
            "description": "File path or reference to the harness definition"
          },
          "version": {
            "type": "string",
            "description": "Current version of this entry"
          },
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Categorization tags"
          },
          "dependencies": {
            "type": "array",
            "items": {"type": "string"},
            "description": "List of other entries this depends on"
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "description": "Registry statistics",
      "properties": {
        "total_entries": {
          "type": "integer",
          "description": "Total number of registered entries"
        },
        "active_entries": {
          "type": "integer",
          "description": "Number of active entries"
        },
        "by_type": {
          "type": "object",
          "description": "Count by entry type"
        },
        "by_plane": {
          "type": "object",
          "description": "Count by GAMMA plane"
        }
      }
    }
  },
  "additionalProperties": false
}
